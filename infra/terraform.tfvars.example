project_id = "your-gcp-project-id"
region     = "us-central1"
zone       = "us-central1-a"

# Update these after deploying Cloud Run services
cloud_run_transcription_worker_url = "https://transcription-worker-PLACEHOLDER.run.app"
backend_api_url                    = "https://backend-api-PLACEHOLDER.run.app"

# Cloud SQL settings
cloud_sql_tier          = "db-f1-micro"
cloud_sql_database_name = "notetaker"
