{
    "name": "meeting-notetaker-bot",
    "version": "1.0.0",
    "description": "Playwright headless bot for Leverege Meeting Notetaker",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "dev": "ts-node src/index.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint 'src/**/*.ts'",
        "format": "prettier --write 'src/**/*.ts'"
    },
    "dependencies": {
        "playwright": "^1.41.0",
        "express": "^4.18.2",
        "@google-cloud/storage": "^7.7.0",
        "@google-cloud/secret-manager": "^5.0.1"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "@types/express": "^4.17.21",
        "typescript": "^5.3.3",
        "vitest": "^1.2.0",
        "fast-check": "^3.15.0",
        "eslint": "^8.56.0",
        "@typescript-eslint/eslint-plugin": "^6.19.0",
        "@typescript-eslint/parser": "^6.19.0",
        "prettier": "^3.2.4",
        "ts-node": "^10.9.2"
    }
}