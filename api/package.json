{
    "name": "meeting-notetaker-api",
    "version": "1.0.0",
    "description": "Backend API for Leverege Meeting Notetaker",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "dev": "ts-node src/index.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint 'src/**/*.ts'",
        "format": "prettier --write 'src/**/*.ts'"
    },
    "dependencies": {
        "@google-cloud/secret-manager": "^6.1.1",
        "@google-cloud/storage": "^7.19.0",
        "express": "^4.18.2",
        "express-rate-limit": "^8.3.1",
        "google-auth-library": "^10.6.1",
        "pg": "^8.20.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^20.11.0",
        "@types/pg": "^8.18.0",
        "@types/supertest": "^7.2.0",
        "@typescript-eslint/eslint-plugin": "^6.19.0",
        "@typescript-eslint/parser": "^6.19.0",
        "eslint": "^8.56.0",
        "fast-check": "^3.15.0",
        "prettier": "^3.2.4",
        "supertest": "^7.2.2",
        "typescript": "^5.3.3",
        "vitest": "^1.2.0"
    }
